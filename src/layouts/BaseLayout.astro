        const referencesHeading =
          Array.from(document.querySelectorAll("h2, h3")).find(
            (heading) => normalizeText(heading.textContent) === "참고 자료"
          ) || document.getElementById("참고-자료");

        if (referencesHeading && !referencesHeading.id) {
          referencesHeading.id = "참고-자료";
        }

        let referencesList = null;
        if (referencesHeading) {
          let cursor = referencesHeading.nextElementSibling;
          while (cursor && cursor.tagName !== "OL" && cursor.tagName !== "UL") {
            cursor = cursor.nextElementSibling;
          }
          referencesList = cursor;
        }

        const referenceItems = referencesList
          ? Array.from(referencesList.children).filter((node) => node.tagName === "LI")
          : [];

        referenceItems.forEach((item, index) => {
          if (!item.id) {
            item.id = `cite-source-${index + 1}`;
          }
        });

        const citeWrappers = new Set();

        const closeAll = () => {
          citeWrappers.forEach((wrapper) => {
            wrapper.classList.remove("is-open");
            const trigger = wrapper.querySelector(".cite-ref");
            const tooltip = wrapper.querySelector(".cite-tooltip");
            if (trigger) trigger.setAttribute("aria-expanded", "false");
            if (tooltip) tooltip.setAttribute("aria-hidden", "true");
          });
        };

        const positionTooltip = (wrapper) => {
          if (!(wrapper instanceof HTMLElement)) return;
          const tooltip = wrapper.querySelector(".cite-tooltip");
          if (!(tooltip instanceof HTMLElement)) return;

          tooltip.style.removeProperty("--cite-tooltip-left");
          tooltip.style.removeProperty("--cite-tooltip-shift");
          tooltip.style.removeProperty("max-width");

          const boundary =
            wrapper.closest(".prose") ||
            wrapper.closest(".post-list-item") ||
            wrapper.closest(".site-main") ||
            document.body;
          if (!(boundary instanceof HTMLElement)) return;

          const boundaryRect = boundary.getBoundingClientRect();
          const wrapperRect = wrapper.getBoundingClientRect();
          let tooltipRect = tooltip.getBoundingClientRect();
          const gutter = 10;

          const maxAllowedWidth = Math.max(180, boundaryRect.width - gutter * 2);
          if (tooltipRect.width > maxAllowedWidth) {
            tooltip.style.maxWidth = `${Math.floor(maxAllowedWidth)}px`;
            tooltipRect = tooltip.getBoundingClientRect();
          }

          const minLeft = boundaryRect.left + gutter - wrapperRect.left;
          const maxLeft = boundaryRect.right - gutter - wrapperRect.left - tooltipRect.width;
          let left = wrapperRect.width / 2 - tooltipRect.width / 2;

          if (minLeft <= maxLeft) {
            left = Math.min(Math.max(left, minLeft), maxLeft);
          } else {
            left = minLeft;
          }

          tooltip.style.setProperty("--cite-tooltip-left", `${Math.round(left)}px`);
          tooltip.style.setProperty("--cite-tooltip-shift", "0px");
        };

        const positionVisibleTooltips = () => {
          citeWrappers.forEach((wrapper) => {
            if (!(wrapper instanceof HTMLElement)) return;
            if (
              wrapper.classList.contains("is-open") ||
              wrapper.matches(":hover") ||
              wrapper.matches(":focus-within")
            ) {
              positionTooltip(wrapper);
            }
          });
        };

        citationLinks.forEach((link) => {
          if (link.dataset.citeReady === "true") return;
          link.dataset.citeReady = "true";

          const wrapper = link.closest("sup") || link.parentElement;
          if (!wrapper) return;
          wrapper.classList.add("cite-wrap");
          citeWrappers.add(wrapper);

          const sourceUrl = link.getAttribute("href") || "";
          const citationNumber = parseCitationNumber(link.textContent || link.dataset.cite || link.title);
          const matchedReference = citationNumber ? referenceItems[citationNumber - 1] : null;
          const targetId = matchedReference?.id || referencesHeading?.id || "참고-자료";
          const sourceName =
            cleanSourceLabel(link.dataset.cite || link.getAttribute("title")) ||
            normalizeText(matchedReference?.textContent) ||
            "원문 자료";
          const normalizedSourceUrl = sourceUrl.replace(/#.*$/, "");
          const normalizedSourceUrlNoSlash = normalizedSourceUrl.replace(/\/$/, "");
          const normalizedSourceUrlWithSlash = normalizedSourceUrlNoSlash
            ? `${normalizedSourceUrlNoSlash}/`
            : normalizedSourceUrl;
          const registryMatch =
            sourceExcerptRegistry[sourceUrl] ||
            sourceExcerptRegistry[normalizedSourceUrl] ||
            sourceExcerptRegistry[normalizedSourceUrlNoSlash] ||
            sourceExcerptRegistry[normalizedSourceUrlWithSlash] ||
            null;
          const sourceExcerpt =
            normalizeText(link.getAttribute("data-cite-source-excerpt")) || normalizeText(registryMatch?.excerpt);
          const sourceExcerptOrigin =
            normalizeText(link.getAttribute("data-cite-source-origin")) ||
            normalizeText(registryMatch?.origin);
          const sourceHighlight =
            normalizeText(link.getAttribute("data-cite-highlight")) ||
            normalizeText(registryMatch?.highlight);
          const excerptLabelText = sourceExcerpt
            ? sourceExcerptOrigin
              ? `원문 발췌 (${sourceExcerptOrigin})`
              : "원문 발췌"
            : "원문 발췌 미등록";
          const excerptText = sourceExcerpt || "출처 원문 발췌가 등록되지 않았습니다. 해당 인용을 검수해 주세요.";

          link.setAttribute("href", `#${targetId}`);
          link.removeAttribute("target");
          link.setAttribute("aria-haspopup", "dialog");
          link.setAttribute("aria-expanded", "false");
          link.setAttribute("aria-label", `출처 ${citationNumber || ""} 상세 보기`);
          link.removeAttribute("title");

          if (!wrapper.querySelector(".cite-tooltip")) {
            const tooltip = document.createElement("span");
            tooltip.className = "cite-tooltip";
            tooltip.setAttribute("role", "tooltip");
            tooltip.setAttribute("aria-hidden", "true");

            const header = document.createElement("span");
            header.className = "cite-tooltip-head";

            const jumpLink = document.createElement("a");
            jumpLink.className = "cite-jump";
            jumpLink.href = `#${targetId}`;
            jumpLink.textContent = `#${citationNumber || "?"}`;
            jumpLink.setAttribute("title", "화면 하단 참고 자료로 이동");

            const sourceTitle = document.createElement("a");
            sourceTitle.className = "cite-source-link";
            sourceTitle.href = sourceUrl;
            sourceTitle.target = "_blank";
            sourceTitle.rel = "noopener noreferrer";
            sourceTitle.setAttribute("title", "원문을 새 창에서 열기");
            sourceTitle.textContent = sourceName;

            const externalLink = document.createElement("a");
            externalLink.className = "cite-external";
            externalLink.href = sourceUrl;
            externalLink.target = "_blank";
            externalLink.rel = "noopener noreferrer";
            externalLink.textContent = "출처 보기";
            externalLink.setAttribute("title", "원문을 새 창에서 열기");

            const excerptLabel = document.createElement("span");
            excerptLabel.className = "cite-quote-label";
            excerptLabel.textContent = excerptLabelText;

            const excerpt = document.createElement("span");
            excerpt.className = "cite-quote";
            excerpt.innerHTML = highlightExcerptHtml(excerptText, sourceHighlight);

            header.appendChild(jumpLink);
            header.appendChild(sourceTitle);
            header.appendChild(externalLink);
            tooltip.appendChild(header);
            tooltip.appendChild(excerptLabel);
            tooltip.appendChild(excerpt);
            wrapper.appendChild(tooltip);

            jumpLink.addEventListener("click", () => {
              closeAll();
            });

            externalLink.addEventListener("click", (event) => {
              event.stopPropagation();
              closeAll();
            });

            sourceTitle.addEventListener("click", (event) => {
              event.stopPropagation();
              closeAll();
            });
          }

          link.addEventListener("click", (event) => {
            event.preventDefault();
            event.stopPropagation();
            const isOpen = wrapper.classList.contains("is-open");
            closeAll();
            if (!isOpen) {
              positionTooltip(wrapper);
              wrapper.classList.add("is-open");
              link.setAttribute("aria-expanded", "true");
              const tooltip = wrapper.querySelector(".cite-tooltip");
              if (tooltip) tooltip.setAttribute("aria-hidden", "false");
            }
          });

          link.addEventListener("keydown", (event) => {
            if (event.key === " ") {
              event.preventDefault();
              link.click();
            }
            if (event.key === "Escape") {
              closeAll();
            }
          });

          link.addEventListener("focus", () => {
            positionTooltip(wrapper);
          });

          wrapper.addEventListener("mouseenter", () => {
            positionTooltip(wrapper);
            const tooltip = wrapper.querySelector(".cite-tooltip");
            if (tooltip) tooltip.setAttribute("aria-hidden", "false");
          });

          wrapper.addEventListener("mouseleave", () => {
            if (wrapper.classList.contains("is-open")) return;
            const tooltip = wrapper.querySelector(".cite-tooltip");
            if (tooltip) tooltip.setAttribute("aria-hidden", "true");
          });
        });

        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Node)) return;
          for (const wrapper of citeWrappers) {
            if (wrapper.contains(target)) return;
          }
          closeAll();
        });

        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape") {
            closeAll();
          }
        });

        window.addEventListener("resize", positionVisibleTooltips, { passive: true });
        window.addEventListener("scroll", positionVisibleTooltips, { passive: true });
      })();

      (() => {
        const sliders = Array.from(document.querySelectorAll("[data-anl-slider]"));
        if (!sliders.length) return;

        sliders.forEach((slider) => {
          const slides = Array.from(slider.querySelectorAll(".anl-slide"));
          if (!slides.length) return;

          const stage = slider.querySelector(".anl-slider-stage");
          const prevButton = slider.querySelector("[data-slider-prev]");
          const nextButton = slider.querySelector("[data-slider-next]");
          const status = slider.querySelector("[data-slider-status]");
          const dots = Array.from(slider.querySelectorAll("[data-slider-dot]"));

          let currentIndex = slides.findIndex((slide) => slide.classList.contains("is-active"));
          if (currentIndex < 0) currentIndex = 0;
          let touchStartX = 0;
          let touchStartY = 0;
          let touchActive = false;

          const update = (nextIndex) => {
            currentIndex = (nextIndex + slides.length) % slides.length;

            slides.forEach((slide, index) => {
              const isActive = index === currentIndex;
              slide.classList.toggle("is-active", isActive);
              slide.hidden = !isActive;
              slide.setAttribute("aria-hidden", String(!isActive));
            });

            dots.forEach((dot, index) => {
              const isActive = index === currentIndex;
              dot.classList.toggle("is-active", isActive);
              dot.setAttribute("aria-selected", String(isActive));
              dot.setAttribute("tabindex", isActive ? "0" : "-1");
            });

            if (status) {
              status.textContent = `${currentIndex + 1} / ${slides.length}`;
            }
          };

          prevButton?.addEventListener("click", () => {
            update(currentIndex - 1);
          });

          nextButton?.addEventListener("click", () => {
            update(currentIndex + 1);
          });

          dots.forEach((dot, index) => {
            dot.addEventListener("click", () => {
              update(index);
            });

            dot.addEventListener("keydown", (event) => {
              if (event.key === "ArrowLeft") {
                event.preventDefault();
                update(currentIndex - 1);
              }
              if (event.key === "ArrowRight") {
                event.preventDefault();
                update(currentIndex + 1);
              }
              if (event.key === "Home") {
                event.preventDefault();
                update(0);
              }
              if (event.key === "End") {
                event.preventDefault();
                update(slides.length - 1);
              }
            });
          });

          slider.addEventListener("keydown", (event) => {
            if (event.key === "ArrowLeft") {
              event.preventDefault();
              update(currentIndex - 1);
            }
            if (event.key === "ArrowRight") {
              event.preventDefault();
              update(currentIndex + 1);
            }
          });

          stage?.addEventListener(
            "touchstart",
            (event) => {
              const touch = event.changedTouches[0];
              if (!touch) return;
              touchStartX = touch.clientX;
              touchStartY = touch.clientY;
              touchActive = true;
            },
            { passive: true }
          );

          stage?.addEventListener(
            "touchend",
            (event) => {
              if (!touchActive) return;
              touchActive = false;

              const touch = event.changedTouches[0];
              if (!touch) return;

              const deltaX = touch.clientX - touchStartX;
              const deltaY = touch.clientY - touchStartY;

              if (Math.abs(deltaX) < 36) return;
              if (Math.abs(deltaX) <= Math.abs(deltaY)) return;

              if (deltaX < 0) {
                update(currentIndex + 1);
                return;
              }

              update(currentIndex - 1);
            },
            { passive: true }
          );

          stage?.addEventListener("touchcancel", () => {
            touchActive = false;
          });

          update(currentIndex);
        });
      })();
    </script>
  </body>
</html>
