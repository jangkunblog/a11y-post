---
import type { CollectionEntry } from "astro:content";
import { getPostUrl, getTitleParts } from "../utils/posts";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const rawTitle = post.data.title.trim();
const { titleMain, titleSub } = getTitleParts(rawTitle);
const href = getPostUrl(post);
---

<li class="post-list-item">
  <h2 class="post-title">
    <a href={href} aria-label={rawTitle}>
      <span class="post-title-main">{titleMain}</span>
      {titleSub && <span class="post-title-sub">{titleSub}</span>}
    </a>
  </h2>
  <p class="post-date">
    <time datetime={post.data.pubDatetime.toISOString()}>
      {post.data.pubDatetime.toLocaleDateString("ko-KR", {
        year: "numeric",
        month: "long",
        day: "numeric"
      })}
    </time>
  </p>
  <p class="post-description">{post.data.description}</p>
</li>
