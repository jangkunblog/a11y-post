---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const now = new Date();

  return posts
    .filter((post) => !post.data.draft && post.data.pubDatetime <= now)
    .map((post) => ({
      params: { slug: post.slug },
      props: { post }
    }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { Content } = await post.render();
const rawTitle = post.data.title.trim();
const delimiterIndex = rawTitle.search(/[:：]/);
const hasSubtitle = delimiterIndex > -1;
const titleMain = hasSubtitle ? rawTitle.slice(0, delimiterIndex).trim() : rawTitle;
const titleSub = hasSubtitle ? rawTitle.slice(delimiterIndex + 1).trim() : "";
---

<BaseLayout title={`${post.data.title} | 디지털 접근성 아카이브`} description={post.data.description}>
  <article>
    <div class="prose">
      <div class="title">
        <div class="date">
          <time datetime={post.data.pubDatetime.toISOString()}>
            {post.data.pubDatetime.toLocaleDateString("ko-KR", {
              year: "numeric",
              month: "long",
              day: "numeric"
            })}
          </time>
        </div>
        <h1 class="post-detail-title" aria-label={rawTitle}>
          <span class="post-detail-title-main">{titleMain}</span>
          {titleSub && <span class="post-detail-title-sub">{titleSub}</span>}
        </h1>
        <hr />
      </div>
      <Content />
    </div>
  </article>
</BaseLayout>
