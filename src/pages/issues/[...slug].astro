---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostDetailArticle from "../../components/PostDetailArticle.astro";
import { isIssueReport } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const now = new Date();

  return posts
    .filter((post) => !post.data.draft && post.data.pubDatetime <= now && isIssueReport(post))
    .map((post) => ({
      params: { slug: post.slug },
      props: { post }
    }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
---

<BaseLayout title={`${post.data.title} | 디지털 접근성 아카이브`} description={post.data.description}>
  <PostDetailArticle post={post} />
</BaseLayout>
