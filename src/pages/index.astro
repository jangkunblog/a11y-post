---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getVisiblePosts } from "../utils/posts";

const allPosts = getVisiblePosts(await getCollection("posts"));
const posts = allPosts;
---

<BaseLayout title="디지털 접근성 뉴스" description="웹 접근성과 디지털 포용에 관한 최신 소식을 기록합니다.">
  <section class="home-intro">
    <h1>디지털 접근성 뉴스</h1>
    <p>
      웹 접근성과 디지털 포용에 관한 표준 변화, 실무 사례, 제품 운영 인사이트를
      한 화면에서 바로 읽을 수 있도록 정리합니다.
    </p>
  </section>

  <section>
    {posts.length === 0 ? (
      <p>아직 게시된 글이 없습니다.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
